# Arki Engine v30.1 TITANIUM — Environment Variables

# ── Required ──
BOT_TOKEN=your_telegram_bot_token
AI_API_KEY=your_gemini_api_key

# ── Optional Providers ──
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key

# ── Claude Ultra (free-claude-code proxy) ──
# Run free-claude-code server first, then configure:
CLAUDE_ULTRA_BASE_URL=http://localhost:8082
CLAUDE_ULTRA_AUTH_TOKEN=freecc

# ── Image & Video Generation (v30.1) ──
# Pollinations.ai is the default (free, no key needed)
# Optional: HuggingFace free tier for video generation
HF_TOKEN=your_huggingface_token
# Optional: Together.ai free $1 credit
TOGETHER_API_KEY=your_together_key

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ── Admin ──
ADMIN_IDS=your_telegram_user_id
